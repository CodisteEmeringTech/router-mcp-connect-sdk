{
  "name": "@routemcp/connect-sdk",
  "version": "1.0.1",
  "description": "Connect SDK — embed the provider connection flow in any web app",
  "license": "MIT",
  "homepage": "https://routemcp.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodisteEmeringTech/router-mcp-connect-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/CodisteEmeringTech/router-mcp-connect-sdk/issues"
  },
  "keywords": [
    "connect",
    "integration",
    "sdk",
    "iframe",
    "oauth"
  ],
  "author": "Codiste Emerging Tech",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
